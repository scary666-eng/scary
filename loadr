local function executeAndClose(url)
    for _,v in pairs(container:GetDescendants()) do
        if v:IsA("TextButton") then
            v.AutoButtonColor = false
            v.Active = false
        end
    end
    local blurOut = TweenService:Create(blur, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {Size = 0})
    blurOut:Play()
    blurOut.Completed:Connect(function()
        if blur and blur.Parent then
            blur:Destroy()
        end
    end)
    if screenGui and screenGui.Parent then
        screenGui:Destroy()
    end
    spawn(function()
        pcall(function()
            loadstring(game:HttpGet(url))()
        end)
    end)
end

